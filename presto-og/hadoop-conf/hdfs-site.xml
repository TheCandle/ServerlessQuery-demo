<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
  <property>
    <name>dfs.replication</name>
    <value>1</value>
  </property>
  <property>
    <name>dfs.client.socket-timeout</name>
    <value>600000</value>  <!-- 10 分钟，单位毫秒 -->
    <description>客户端 socket 超时时间</description>
  </property>
  <property>
    <name>dfs.datanode.socket.write.timeout</name>
    <value>600000</value>
    <description>DataNode 写超时</description>
  </property>
  <property>
    <name>dfs.datanode.socket.read.timeout</name>
    <value>600000</value>
    <description>DataNode 读超时</description>
  </property>
  <property>
    <name>dfs.datanode.max.xcievers</name>
    <value>8192</value> <!-- 根据需要增加到更高的值 -->
  </property>
  <property>
    <name>dfs.datanode.max.transfer.threads</name>
    <value>8192</value>   <!-- 适当增大，根据并发需求调整 -->
  </property>
</configuration>
